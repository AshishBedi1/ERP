# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/erp_db

# JWT Secret (use a strong secret in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Port
PORT=5000

# Set to true to show “Reset today” on Attendance (dev/testing only; keep false in production)
ALLOW_ATTENDANCE_TEST_RESET=false

# OpenAI (optional) — “Polish with AI” on Today’s plan. Use server-side key only.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

OPENAI_API_KEY=your_openai_api_key_here
